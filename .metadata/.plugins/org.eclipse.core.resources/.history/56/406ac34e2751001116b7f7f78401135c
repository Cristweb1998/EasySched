import { Component, OnInit, ChangeDetectorRef } from '@angular/core';
import { CommonModule } from '@angular/common';
import { UserService } from './services/user'; 

@Component({
  selector: 'app-root',
  standalone: true,
  imports: [CommonModule],
  template: `
    <div style="padding: 20px; font-family: sans-serif;">
      <!-- Modifichiamo temporaneamente il titolo per vedere se Eclipse si aggiorna -->
      <h1>EasySched - Dashboard (Test Collegamento)</h1>
      <hr>
      
      <!-- Visualizziamo il numero reale di utenti -->
      <p><strong>Numero utenti trovati:</strong> {{ utenti.length }}</p>

      <!-- Lista degli utenti -->
      <ul *ngIf="utenti.length > 0">
        <li *ngFor="let u of utenti" style="margin-bottom: 10px;">
          <strong>{{ u.nome }}</strong> ({{ u.email }}) 
          <br><small style="color: gray;">ID Database: {{ u.id }}</small>
        </li>
      </ul>

      <!-- Messaggio se l'array è ancora vuoto nella pagina -->
      <p *ngIf="utenti.length === 0" style="color: red;">
        Nessun utente visualizzato a schermo (In attesa dei dati...).
      </p>

      <hr>
      <!-- Box di debug per vedere i dati grezzi passati alla grafica -->
      <pre style="background: #eee; padding: 10px; border: 1px solid #ccc;">Debug Vista HTML: {{ utenti | json }}</pre>
    </div>
  `
})
export class App implements OnInit {
  // Inizializziamo l'array vuoto
  utenti: any[] = [];

  // Iniettiamo il servizio per Java e il gestore della grafica (cdr)
  constructor(
    private userService: UserService,
    private cdr: ChangeDetectorRef 
  ) {}

  ngOnInit() {
    console.log("Componente avviato, chiedo i dati a Java...");
    
    this.userService.getUsers().subscribe({
      next: (data: any) => {
        console.log("Dati ricevuti dal server:", data);
        
        // Controllo di sicurezza per estrarre l'array in ogni scenario
        if (Array.isArray(data)) {
          this.utenti = data;
        } else if (data && data.content) {
          this.utenti = data.content;
        } else {
          this.utenti = [data]; 
        }

        // Forza il browser a ridisegnare la pagina con i nuovi dati
        this.cdr.detectChanges(); 
      },
      error: (err) => {
        console.error("ERRORE NELLA CHIAMATA HTTP:", err);
      }
    });
  }
}