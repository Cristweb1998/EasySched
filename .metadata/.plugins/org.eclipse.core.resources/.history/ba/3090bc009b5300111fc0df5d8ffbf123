package com.easysched.backend.controller;

import com.easysched.backend.model.User;
import com.easysched.backend.service.UserService;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;

import java.util.List;

@RestController
@RequestMapping("/api/users")
@CrossOrigin(origins = "*") // <-- MODIFICATO: Ora permette ad Angular di parlare con Java da qualsiasi porta (sia 4200 che 4201)
public class UserController {

    @Autowired
    private UserService userService; // Usiamo il Service per la logica di business

    // --- LEGGERE TUTTI ---
    @GetMapping
    public List<User> getAllUsers() {
        return userService.findAllUsers();
    }

    // --- LEGGERE SINGOLO ---
    @GetMapping("/{id}")
    public ResponseEntity<User> getUserById(@PathVariable Long id) {
        return userService.findUserById(id)
                .map(user -> ResponseEntity.ok().body(user))
                .orElse(ResponseEntity.notFound().build());
    }

    // --- CREARE ---
    @PostMapping
    public User createUser(@RequestBody User user) {
        return userService.saveUser(user);
    }

    // --- MODIFICARE (Update) ---
    @PutMapping("/{id}")
    public ResponseEntity<User> updateUser(@PathVariable Long id, @RequestBody User userDetails) {
        return userService.findUserById(id)
                .map(user -> {
                    // Aggiorniamo i campi dell'utente trovato con quelli che arrivano dal frontend
                    user.setNome(userDetails.getNome());
                    user.setEmail(userDetails.getEmail());
                    
                    // Salviamo le modifiche tramite il service
                    User updatedUser = userService.saveUser(user);
                    return ResponseEntity.ok(updatedUser);
                })
                .orElse(ResponseEntity.notFound().build());
    }

    // --- CANCELLARE ---
    @DeleteMapping("/{id}")
    public ResponseEntity<Void> deleteUser(@PathVariable Long id) {
        return userService.findUserById(id)
                .map(user -> {
                    userService.deleteUser(id);
                    return ResponseEntity.ok().<Void>build();
                })
                .orElse(ResponseEntity.notFound().build());
    }
}